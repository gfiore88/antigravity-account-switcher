{
  "name": "antigravity-account-switcher",
  "displayName": "Antigravity Account Switcher",
  "description": "Switch between multiple Google accounts (with AI Pro subscriptions) seamlessly in Antigravity IDE — with a beautiful built-in UI panel.",
  "version": "1.0.2",
  "publisher": "gfiore88",
  "author": {
    "name": "Giovanni Fiore",
    "url": "https://www.giovannifiore.net"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gfiore88/antigravity-account-switcher"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "google",
    "account",
    "switcher",
    "profile",
    "antigravity"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "antigravity.openPanel",
        "title": "Antigravity: Open Account Switcher",
        "icon": {
          "light": "icon.png",
          "dark": "icon.png"
        }
      },
      {
        "command": "antigravity.switchAccount",
        "title": "Antigravity: Switch Google Account"
      },
      {
        "command": "antigravity.saveCurrentAccount",
        "title": "Antigravity: Save Current Account Profile"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "antigravity-account-switcher",
          "title": "Account Switcher",
          "icon": "icon.png"
        }
      ]
    },
    "views": {
      "antigravity-account-switcher": [
        {
          "type": "webview",
          "id": "antigravity.accountSwitcherView",
          "name": "Account Switcher"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "antigravity.openPanel",
          "when": "true"
        },
        {
          "command": "antigravity.switchAccount",
          "when": "true"
        },
        {
          "command": "antigravity.saveCurrentAccount",
          "when": "true"
        }
      ],
      "editor/title": [
        {
          "command": "antigravity.openPanel",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "ts-loader": "^9.4.3",
    "typescript": "^5.1.3",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "fs-extra": "^11.1.1",
    "@types/fs-extra": "^11.0.1"
  }
}